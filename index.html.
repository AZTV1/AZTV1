<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AZTV1 - سحابة الأفلام</title>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>
    <style>
        body { background-color: #000; color: #fff; font-family: sans-serif; margin: 0; text-align: center; }
        header { padding: 30px; border-bottom: 3px solid #ff0000; background: #050505; color: #FFD700; font-size: 35px; font-weight: bold; }
        .add-section { background: #0a0a0a; padding: 25px; margin: 20px auto; max-width: 450px; border: 1px solid #333; border-radius: 12px; }
        input { width: 85%; padding: 12px; margin: 10px 0; border-radius: 8px; border: 1px solid #444; background: #1a1a1a; color: #fff; text-align: center; font-size: 16px; }
        .btn-add { background: #ff0000; color: #fff; padding: 12px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; width: 90%; font-size: 17px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; padding: 20px; }
        .movie-card { background: #111; border: 1px solid #222; border-radius: 12px; padding: 15px; }
        video { width: 100%; border-radius: 8px; background: #000; }
    </style>
</head>
<body>
    <header>AZTV1</header>
    <div class="add-section">
        <h3 style="color: #ff0000;">إضافة فيلم جديد</h3>
        <input type="text" id="movieName" placeholder="اسم الفيلم">
        <input type="text" id="movieUrl" placeholder="رابط الفيديو المباشر">
        <button class="btn-add" onclick="saveMovie()">إضافة للمكتبة ✅</button>
    </div>
    <div class="grid" id="moviesContainer"></div>
    <script>
        const firebaseConfig = { databaseURL: "https://mymoveis-default-rtdb.firebaseio.com/" };
        firebase.initializeApp(firebaseConfig);
        const db = firebase.database();
        function saveMovie() {
            const name = document.getElementById('movieName').value;
            const url = document.getElementById('movieUrl').value;
            if (name && url) {
                db.ref('movies').push({ name: name, url: url }).then(() => {
                    alert("تمت الإضافة بنجاح!");
                    document.getElementById('movieName').value = "";
                    document.getElementById('movieUrl').value = "";
                });
            }
        }
        db.ref('movies').on('value', (snap) => {
            const container = document.getElementById('moviesContainer');
            container.innerHTML = ""; 
            snap.forEach((child) => {
                const data = child.val();
                container.innerHTML += `<div class="movie-card"><p style="color:#FFD700;font-weight:bold;">${data.name}</p><video controls src="${data.url}"></video></div>`;
            });
        });
    </script>
</body>
</html>
