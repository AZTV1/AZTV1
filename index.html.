<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AZTV1 - سحابة الأفلام</title>
    <!-- استدعاء قاعدة البيانات فقط -->
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>
    
    <style>
        body { background-color: #000; color: #fff; font-family: sans-serif; margin: 0; text-align: center; }
        header { padding: 30px; border-bottom: 3px solid #ff0000; background: #050505; }
        .logo { color: #FFD700; font-size: 35px; font-weight: bold; letter-spacing: 5px; }
        .add-section { background: #0a0a0a; padding: 25px; margin: 20px auto; max-width: 450px; border: 1px solid #333; border-radius: 12px; box-shadow: 0 0 15px rgba(255,0,0,0.2); }
        input { width: 85%; padding: 12px; margin: 10px 0; border-radius: 8px; border: 1px solid #444; background: #1a1a1a; color: #fff; text-align: center; font-size: 16px; }
        .btn-add { background: #ff0000; color: #fff; padding: 12px; border: none; border-radius: 8px; cursor: pointer; font-weight: bold; width: 90%; font-size: 17px; transition: 0.3s; }
        .btn-add:hover { background: #cc0000; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; padding: 20px; }
        .movie-card { background: #111; border: 1px solid #222; border-radius: 12px; padding: 15px; }
        .movie-card p { color: #FFD700; font-weight: bold; margin-bottom: 10px; }
        video { width: 100%; border-radius: 8px; background: #000; }
    </style>
</head>
<body>

<header><div class="logo">AZTV1</div></header>

<div class="add-section">
    <h3 style="color: #ff0000; margin-top: 0;">إضافة فيلم جديد</h3>
    <input type="text" id="movieName" placeholder="اسم الفيلم (مثلاً: فيلم أكشن)">
    <input type="text" id="movieUrl" placeholder="ضع رابط الفيديو المباشر هنا">
    <button class="btn-add" onclick="saveToCloud()">حفظ في المكتبة ✅</button>
</div>

<div class="grid" id="moviesContainer">
    <!-- الأفلام تظهر هنا -->
</div>

<script>
    // إعدادات البرنامج الثاني (Realtime Database)
    // الرابط المأخوذ من الصورة التي أرسلتها أنت
    const firebaseConfig = {
        databaseURL: "https://mymoveis-default-rtdb.firebaseio.com/" 
    };
    
    firebase.initializeApp(firebaseConfig);
    const db = firebase.database();

    // وظيفة الحفظ
    function saveToCloud() {
        const name = document.getElementById('movieName').value;
        const url = document.getElementById('movieUrl').value;

        if (name && url) {
            db.ref('all_movies').push({
                movie_name: name,
                movie_link: url
            }).then(() => {
                alert("تم الحفظ بنجاح! 🎉");
                document.getElementById('movieName').value = "";
                document.getElementById('movieUrl').value = "";
            }).catch((error) => {
                alert("خطأ: تأكد من تفعيل وضع الاختبار (Rules) في Firebase");
            });
        } else {
            alert("فضلاً املأ الفراغات");
        }
    }

    // وظيفة عرض الأفلام تلقائياً
    db.ref('all_movies').on('value', (snapshot) => {
        const container = document.getElementById('moviesContainer');
        container.innerHTML = ""; 
        snapshot.forEach((child) => {
            const data = child.val();
            container.innerHTML += `
                <div class="movie-card">
                    <p>${data.movie_name}</p>
                    <video controls src="${data.movie_link}"></video>
                </div>`;
        });
    });
</script>

</body>
</html>
